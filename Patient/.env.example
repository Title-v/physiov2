# Required for production builds. Points to the deployed Supabase-backed Express API.
# In development only, leaving it blank enables local demo/mock storage.
EXPO_PUBLIC_API_BASE=https://your-physioai-api.example.com

# Optional. Set to true only when you intentionally want guest/demo mode in a build.
EXPO_PUBLIC_ENABLE_DEMO=false

# Supabase project values. Current Patient code talks to the Express API above;
# keep these available for future direct Supabase client usage.
EXPO_PUBLIC_SUPABASE_URL=https://hptkdtzrhotmasznecwj.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_your_publishable_key
